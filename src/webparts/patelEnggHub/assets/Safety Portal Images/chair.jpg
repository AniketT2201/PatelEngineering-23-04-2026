.meter { height: 5px; position: relative; margin-top: 10px; background: rgb=
(255, 255, 255); border-radius: 25px; padding: 3px 5px; border: 1px solid r=
gb(107, 102, 96); box-shadow: rgba(255, 255, 255, 0.3) 0px -1px 1px inset; =
}

.meter > span { display: block; height: 100%; border-radius: 20px 8px 8px 2=
0px; background-color: rgb(43, 194, 83); position: relative; overflow: hidd=
en; }

.meter > span::after, .animate > span > span { content: ""; position: absol=
ute; inset: 0px; background-image: -webkit-gradient(linear, 0 0, 100% 100%,=
 color-stop(0.25, rgba(255, 255, 255, 0.2)), color-stop(0.25, transparent),=
 color-stop(0.5, transparent), color-stop(0.5, rgba(255, 255, 255, 0.2)), c=
olor-stop(0.75, rgba(255, 255, 255, 0.2)), color-stop(0.75, transparent), t=
o(transparent)); z-index: 1; background-size: 50px 50px; animation: 2s line=
ar 0s infinite normal none running move; border-radius: 20px 8px 8px 20px; =
overflow: hidden; }

.animate > span::after { display: none; }

@-webkit-keyframes move {=20
  0% { background-position: 0px 0px; }
  100% { background-position: 50px 50px; }
}

