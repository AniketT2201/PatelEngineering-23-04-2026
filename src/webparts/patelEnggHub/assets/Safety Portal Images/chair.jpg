ont-weight: bold; line-height: 27px; margin-right: 0px; }

.gsc-refinementHeader.gsc-refinementhActive { border-bottom: 2px solid rgb(=
26, 115, 232); color: rgb(26, 115, 232); }

.gsc-webResult.gsc-result { border: 1px solid rgb(255, 255, 255); }

.gs-result .gs-title *, .gsc-cursor-page, .gs-spelling a { color: rgb(17, 8=
5, 204); }

.gs-webResult .gs-snippet, .gs-fileFormatType { color: rgb(51, 51, 51); }

.gsc-webResult.gsc-result.gsc-promotion { background-color: rgb(246, 246, 2=
46); border-color: rgb(246, 246, 246); }

.gs-promotion .gs-title:link, .gs-promotion .gs-title:link *, .gs-promotion=
 .gs-snippet a:link { color: rgb(17, 85, 204); }

.gs-promotion .gs-title:visited, .gs-promotion .gs-title:visited *, .gs-pro=
motion .gs-snippet a:visited { color: rgb(17, 85, 204); }

.gs-promotion .gs-title:hover, .gs-promotion .gs-title:hover *, .gs-promoti=
on .gs-snippet a:hover { color: rgb(17, 85, 204); }

.gs-promotion .gs-title:active, .gs-promotion .gs-title:active *, .gs-promo=
tion .gs-snippet a:active { color: rgb(17, 85, 204); }

.gs-promotion .gs-snippet, .gs-promotion .gs-title .gs-promotion-title-righ=
t, .gs-promotion .gs-title .gs-promotion-title-right * { color: rgb(0, 0, 0=
); }

.gs-promotion .gs-visibleUrl, .gs-webResult .gs-visibleUrl { color: rgb(0, =
153, 51); }

.gsc-completion-selected { background: rgb(238, 238, 238); }

.gsc-completion-container { font-family: Roboto, sans-serif; font-size: 16p=
x; background: white; border: 1px solid rgb(204, 204, 204); }

.gsc-completion-title { color: rgb(17, 85, 204); }

.gsc-completion-snippet { color: rgb(0, 0, 0); }

.gsc-results .gsc-cursor-box { margin: 10px; }

.gsc-results .gsc-cursor-box .gsc-cursor-page { text-decoration: none; colo=
r: rgb(102, 102, 102); }

.gsc-results .gsc-cursor-box .gsc-cursor-page:hover { text-decoration: unde=
rline; }

.gsc-results .gsc-cursor-box .gsc-cursor-current-page { color: rgb(26, 115,=
 232); }

.gsc-context-box .gsc-facet-label { width: 65px; padding-left: 2px; text-de=
coration: underline; color: rgb(17, 85, 204); cursor: pointer; }

.gsc-context-box .gsc-chart { width: 32em; padding: 3px; border-left: 1px s=
olid rgb(17, 85, 204); border-right: 1px solid rgb(17, 85, 204); }

.gsc-context-box .gsc-top { border-top: 1px solid rgb(17, 85, 204); }

.gsc-context-box .gsc-bottom { border-bottom: 1px solid rgb(17, 85, 204); }

.gsc-context-box .gsc-chart div { background: rgb(17, 85, 204); height: 9px=
; }

.gsc-context-box .gsc-facet-result { color: rgb(17, 85, 204); width: 30px; =
text-align: right; padding-right: 5px; }

.gs-webResult .gs-title .gs-title.gsc-usr-group-heading { color: rgb(17, 85=
, 204); cursor: pointer; }

.gs-webResult .gs-title .gs-title.gsc-usr-group-heading b { color: rgb(17, =
85, 204); }

.gcsc-find-more-on-google { color: rgb(17, 85, 204); }

.gcsc-find-more-on-google-magnifier { fill: rgb(17, 85, 204); }
