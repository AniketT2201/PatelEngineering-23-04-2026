x solid rgb(77, 144, 254); box-shadow: rgba(0, 0, 0, 0.3) 0px 1px 2px inset=
; outline: none; }

.gsc-search-button-v2 { font-size: 0px; padding: 6px 27px; width: auto; ver=
tical-align: middle; border: 1px solid rgb(48, 121, 237); border-radius: 2p=
x; background-color: rgb(77, 144, 254); }

.gsc-search-button-v2:hover { border-color: rgb(47, 91, 183); background-co=
lor: rgb(53, 122, 232); }

.gsc-search-button-v2 svg { fill: rgb(255, 255, 255); }

.gsc-tabHeader.gsc-tabhInactive { color: rgb(102, 102, 102); }

